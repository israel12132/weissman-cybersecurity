# =============================================================================
# Weissman — PRODUCTION environment template
# =============================================================================
# Source of truth: Rust workspace reads these via std::env::var / dotenvy.
# NixOS: use services.weissman-bot.environmentFile (chmod 600, root-owned).
# Never commit filled secrets. Replace placeholders before deploy.
#
# Tracing: RUST_LOG is read by tracing-subscriber (e.g. RUST_LOG=info,weissman_server=debug).
# =============================================================================

# -----------------------------------------------------------------------------
# Core process (weissman-server / weissman-worker)
# -----------------------------------------------------------------------------

# HTTP listen port for weissman-server (backend/weissman-server/src/lib.rs). Default in code is 8000 if unset.
# MUST match Nginx upstream (deploy/nginx-weissman.conf) — use deploy/fix-weissman-502.sh after changes.
PORT=8000

# Optional: additional env file loaded last (overrides); use when systemd WorkingDirectory is not the repo.
# WEISSMAN_ENV_FILE=/etc/weissman/weissman.env

# Primary Postgres URL for RLS app role (weissman_app). Required for server & worker.
# Format: postgres://USER:PASS@HOST:PORT/DB?sslmode=require
DATABASE_URL=

# Optional: separate DB URL for login/bootstrap/user_refresh_tokens (weissman_auth role).
# If unset, DATABASE_URL is used (crates/weissman-db/src/lib.rs).
WEISSMAN_AUTH_DATABASE_URL=

# Optional: DB holding intel schema (dynamic_payloads, ephemeral_payloads, etc.).
# If unset, falls back to DATABASE_URL (crates/weissman-db/src/lib.rs).
WEISSMAN_INTEL_DATABASE_URL=

# Superuser or migration-capable URL. When set, weissman-server runs SQL migrations at startup.
# Leave empty if you run migrations out-of-band (backend/weissman-server/src/lib.rs).
WEISSMAN_MIGRATE_URL=

# weissman-worker: max concurrent jobs. "Heavy" = auto_heal, tenant scans, pipeline, threat intel, Docker/cloud, etc.
# Light jobs share LIGHT slots; heavy jobs share HEAVY slots (prevents one class starving the other).
WEISSMAN_WORKER_LIGHT_CONCURRENCY=8
WEISSMAN_WORKER_HEAVY_CONCURRENCY=2

# Swarm Mind: max ASM HTTP(S) graph labels loaded per client run (default 10000; replaces legacy hard cap of 40).
# WEISSMAN_SWARM_ASM_TARGET_LIMIT=10000

# Path to built Command Center static files (React dist). If unset, server searches cwd/../frontend/dist.
WEISSMAN_STATIC=

# -----------------------------------------------------------------------------
# Connection pool sizing (optional)
# -----------------------------------------------------------------------------

# App pool max/min (default 48 / 2).
WEISSMAN_APP_POOL_MAX=
WEISSMAN_APP_POOL_MIN=

# Auth pool max (default 12).
WEISSMAN_AUTH_POOL_MAX=

# Intel pool max (default 16).
WEISSMAN_INTEL_POOL_MAX=

# -----------------------------------------------------------------------------
# Authentication & sessions (REQUIRED for production API)
# -----------------------------------------------------------------------------

# HMAC secret for access JWT and OIDC/SAML state cookies. REQUIRED — no default (fingerprint_engine/src/auth_jwt.rs).
WEISSMAN_JWT_SECRET=

# Access JWT lifetime in minutes (default 15, clamped 5–240).
WEISSMAN_ACCESS_TOKEN_MINUTES=

# Opaque refresh cookie TTL in days (default 30, clamped 1–365) (fingerprint_engine/src/auth_refresh.rs).
WEISSMAN_REFRESH_TOKEN_DAYS=

# -----------------------------------------------------------------------------
# Public URL & SSO
# -----------------------------------------------------------------------------

# Canonical public origin for OIDC/SAML redirects and links (e.g. https://weissmancyber.com).
# Defaults to http://127.0.0.1:8000 if unset (fingerprint_engine/src/oidc_auth.rs, saml_auth.rs).
WEISSMAN_PUBLIC_BASE_URL=https://weissmancyber.com

# Optional override for SAML SP issuer (default: {WEISSMAN_PUBLIC_BASE_URL}/saml/metadata).
WEISSMAN_SAML_SP_ISSUER=

# Path to xmlsec1 binary for SAML assertion verification (production).
WEISSMAN_XMLSEC1_BINARY=

# Lab only: skip SAML crypto verification (NEVER in production).
WEISSMAN_SAML_INSECURE_SKIP_VERIFY=

# -----------------------------------------------------------------------------
# Default admin seed (first-time dev convenience; tighten for production)
# -----------------------------------------------------------------------------

# Email/password used by ensure_admin_user if no matching user exists (crates/weissman-db).
WEISSMAN_ADMIN_EMAIL=
WEISSMAN_ADMIN_PASSWORD=

# One-time “master” bootstrap in tenant slug `default` (email + password OR bcrypt hash).
WEISSMAN_MASTER_BOOTSTRAP_EMAIL=
WEISSMAN_MASTER_BOOTSTRAP_PASSWORD=
# Alternative to password: pre-hashed bcrypt string.
WEISSMAN_MASTER_BOOTSTRAP_BCRYPT=

# -----------------------------------------------------------------------------
# Billing — Paddle (optional; enables strict billing when configured)
# -----------------------------------------------------------------------------

# Paddle Billing API key (Bearer). If non-empty, WEISSMAN_BILLING_STRICT defaults on unless overridden.
PADDLE_API_KEY=

# sandbox | production (fingerprint_engine/src/billing/mod.rs).
PADDLE_ENVIRONMENT=production

# Webhook signing secret (required for POST /hooks/paddle or equivalent webhook path).
PADDLE_WEBHOOK_SECRET=

# Force billing enforcement on/off regardless of PADDLE_API_KEY (1/true or 0/false).
WEISSMAN_BILLING_STRICT=

# Fallback Paddle price IDs if DB billing_plans.paddle_price_id is empty.
WEISSMAN_PADDLE_PRICE_STARTER=
WEISSMAN_PADDLE_PRICE_PROFESSIONAL=
WEISSMAN_PADDLE_PRICE_ENTERPRISE=

# -----------------------------------------------------------------------------
# Threat intelligence & external APIs
# -----------------------------------------------------------------------------

# NVD API key (higher rate limits; optional but recommended) (fingerprint_engine/src/nvd_cve.rs, threat_intel_engine.rs).
NVD_API_KEY=

# GitHub token for threat ingest / API calls (fingerprint_engine/src/threat_intel_ingestor.rs).
GITHUB_TOKEN=

# In-memory intel HTTP cache entry cap (default 8192, min 256) (fingerprint_engine/src/intel_http_cache.rs).
WEISSMAN_INTEL_CACHE_MAX_ENTRIES=

# Background threat ingest: interval seconds (min 600, default 3600).
WEISSMAN_THREAT_INGEST_INTERVAL_SECS=

# Set to 1 to enable periodic threat ingest worker loop.
WEISSMAN_THREAT_INGEST_CRON=

# -----------------------------------------------------------------------------
# LLM / vLLM / OpenAI-compatible API
# -----------------------------------------------------------------------------

# Base URL for chat completions (OpenAI-compatible), e.g. http://127.0.0.1:8000/v1
# Used when tenant system_configs keys are empty; alias LLM_BASE_URL (threat_intel_ingestor, phase5 handlers).
WEISSMAN_LLM_BASE_URL=
LLM_BASE_URL=

# Model id when tenant config empty (backend/weissman-engines/src/openai_chat.rs, threat_intel_ingestor).
WEISSMAN_LLM_MODEL=

# Optional Bearer token for LLM gateway / vLLM front door (backend/weissman-engines/src/openai_chat.rs).
WEISSMAN_LLM_API_KEY=

# -----------------------------------------------------------------------------
# Hugging Face (NOT read by Weissman Rust binaries — used by vLLM service / model download)
# Set on the vLLM host or in services.weissman-vllm.secretsFile (nix/nixos-modules/weissman-vllm.nix).
# -----------------------------------------------------------------------------

HUGGING_FACE_HUB_TOKEN=

# vLLM on CPU (Ryzen / Xeon): set on the inference host so PyTorch/BLAS matches physical threads (NixOS module sets these for services.weissman-vllm).
# OMP_NUM_THREADS=32
# MKL_NUM_THREADS=32
# OPENBLAS_NUM_THREADS=32
# NUMEXPR_NUM_THREADS=32
# TORCH_NUM_INTRAOP_THREADS=32
# TORCH_NUM_INTEROP_THREADS=4
# Example high-concurrency serve flags (see nix/nixos-modules/weissman-vllm.nix defaults): --device cpu --quantization int8 --max-num-seqs 32 --max-model-len 16384 --max-num-batched-tokens 65536

# -----------------------------------------------------------------------------
# Global rate limits (weissman-server) — numeric overrides
# -----------------------------------------------------------------------------

# General API: requests per second and burst.
WEISSMAN_RATE_LIMIT_PER_SEC=
WEISSMAN_RATE_LIMIT_BURST=

# Login endpoint: per minute and burst.
WEISSMAN_LOGIN_PER_MINUTE=
WEISSMAN_LOGIN_BURST=

# Onboarding signup: per minute and burst.
WEISSMAN_SIGNUP_PER_MINUTE=
WEISSMAN_SIGNUP_BURST=

# Paddle webhook endpoint.
WEISSMAN_PADDLE_WEBHOOK_PER_MINUTE=
WEISSMAN_PADDLE_WEBHOOK_BURST=

# -----------------------------------------------------------------------------
# Per-tenant scan POST rate limit (fingerprint_engine/src/http/tenant_scan_limit.rs)
# -----------------------------------------------------------------------------

WEISSMAN_TENANT_SCAN_POSTS_PER_MINUTE=
WEISSMAN_TENANT_SCAN_BURST=

# -----------------------------------------------------------------------------
# Security, TLS, destructive actions
# -----------------------------------------------------------------------------

# Disable HSTS/CSP/etc. for local HTTP labs only (backend/weissman-server/src/middleware/security_headers.rs).
WEISSMAN_DISABLE_SECURITY_HEADERS=

# Global outbound TLS verify bypass for probes (lab only) (backend/weissman-core/src/tls_policy.rs).
WEISSMAN_ALLOW_INSECURE_TLS=

# Shared secret: clients must send X-Weissman-Destructive-Confirm matching this for containment/auto-heal etc.
WEISSMAN_DESTRUCTIVE_CONFIRM_SECRET=

# Allow scanning loopback/private targets (1/true) (fingerprint_engine/src/security_hardening.rs).
WEISSMAN_ALLOW_PRIVATE_SCAN_TARGETS=

# Sealed PoC / exploit crypto: 64 hex chars (32 bytes). Required for decrypt-sealed-poc flows.
WEISSMAN_EXPLOIT_MASTER_KEY=

# Session crypto policy flag: hybrid_ml_kem768 / pqc / hybrid (fingerprint_engine/src/crypto_policy.rs).
WEISSMAN_SESSION_KEM_MODE=

# -----------------------------------------------------------------------------
# Observability & metrics
# -----------------------------------------------------------------------------

# json = JSON logs; otherwise plain text (fingerprint_engine/src/observability.rs).
WEISSMAN_LOG_FORMAT=

# tracing-subscriber filter (standard Rust ecosystem).
RUST_LOG=info

# If set, GET /api/metrics requires Authorization: Bearer <this token> (fingerprint_engine/src/observability.rs).
WEISSMAN_METRICS_TOKEN=

# -----------------------------------------------------------------------------
# Data retention (Phase 9) — optional tuning
# -----------------------------------------------------------------------------

# Days to retain intel.ephemeral_payloads (default 7).
WEISSMAN_INTEL_EPHEMERAL_RETENTION_DAYS=

# Days to retain intel.dynamic_payloads (default 90).
WEISSMAN_INTEL_DYNAMIC_RETENTION_DAYS=

# Days to retain completed/failed/dead weissman_async_jobs (default 30).
WEISSMAN_ASYNC_JOB_RETENTION_DAYS=

# Set to disable the retention background task entirely.
WEISSMAN_DISABLE_DATA_RETENTION=

# -----------------------------------------------------------------------------
# HTTP client pools (outbound scans) (fingerprint_engine/src/scan_http_client.rs)
# -----------------------------------------------------------------------------

WEISSMAN_HTTP_POOL_MAX_IDLE=
WEISSMAN_HTTP_POOL_IDLE_SECS=
WEISSMAN_HTTP_TCP_KEEPALIVE_SECS=

# -----------------------------------------------------------------------------
# Scan concurrency (fingerprint_engine/src/scan_concurrency.rs)
# -----------------------------------------------------------------------------

WEISSMAN_MAX_CONCURRENT_FULL_SCANS=
WEISSMAN_SCAN_QUEUE_WAIT_SECS=

# -----------------------------------------------------------------------------
# Background workers (server process spawns these)
# -----------------------------------------------------------------------------

# Red team cron: set WEISSMAN_REDTEAM_CRON=1 to enable; interval WEISSMAN_REDTEAM_INTERVAL_SECS (default 86400).
WEISSMAN_REDTEAM_INTERVAL_SECS=
WEISSMAN_REDTEAM_CRON=

# -----------------------------------------------------------------------------
# PostgreSQL backup (manual API + optional scheduler) (fingerprint_engine/src/db_backup.rs)
# -----------------------------------------------------------------------------

# If set, enables backup scheduler + manual backup target directory.
WEISSMAN_PG_BACKUP_DIR=

WEISSMAN_BACKUP_RETENTION_DAYS=
WEISSMAN_BACKUP_MAX_FILES=
WEISSMAN_BACKUP_COMPRESS=

# pg_dump binary path (default: pg_dump on PATH).
WEISSMAN_PG_DUMP_PATH=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------

# Enterprise alert webhook from DB can override; this env is read in notifications path (fingerprint_engine/src/notifications.rs).
WEISSMAN_ALERT_WEBHOOK_URL=

# Legacy / reporter hook (fingerprint_engine/src/reporter.rs).
NOTIFY_URL=

# SMTP (when WEISSMAN_SMTP_ENABLED=1|true|yes).
WEISSMAN_SMTP_ENABLED=
WEISSMAN_SMTP_HOST=
WEISSMAN_SMTP_PORT=
WEISSMAN_SMTP_USER=
WEISSMAN_SMTP_PASSWORD=
WEISSMAN_SMTP_FROM=
WEISSMAN_SMTP_TO=

# -----------------------------------------------------------------------------
# CI/CD webhooks & repo tokens (fingerprint_engine/src/cicd_interceptor.rs)
# -----------------------------------------------------------------------------

WEISSMAN_CICD_WEBHOOK_SECRET=
WEISSMAN_GITHUB_TOKEN=
WEISSMAN_GITLAB_WEBHOOK_SECRET=
WEISSMAN_GITLAB_BASE_URL=
WEISSMAN_GITLAB_TOKEN=
WEISSMAN_BITBUCKET_WEBHOOK_SECRET=
WEISSMAN_BITBUCKET_USER=
WEISSMAN_BITBUCKET_APP_PASSWORD=
WEISSMAN_CICD_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Deception / AWS events (fingerprint_engine/src/server_handlers_phase4.inc)
# -----------------------------------------------------------------------------

WEISSMAN_DECEPTION_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Auto-heal (fingerprint_engine/src/server_handlers_rest4.inc)
# -----------------------------------------------------------------------------

# Skip Docker sandbox for auto-heal (lab only).
WEISSMAN_AUTOHEAL_SKIP_SANDBOX=

# -----------------------------------------------------------------------------
# Cloud containment & AWS (fingerprint_engine cloud modules)
# -----------------------------------------------------------------------------

# Comma-separated regions for EC2 SG pass (fingerprint_engine/src/cloud_integration_engine.rs).
WEISSMAN_AWS_EC2_SCAN_REGIONS=

# VPC DNS CIDR for AWS SG quarantine mode (default 10.0.0.2/32).
WEISSMAN_QUARANTINE_VPC_DNS_CIDR=

# Standard AWS SDK credential chain (not hardcoded in repo): use when not using instance roles.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=
AWS_DEFAULT_REGION=

# -----------------------------------------------------------------------------
# Kubernetes containment — dynamic token variable
# -----------------------------------------------------------------------------

# Containment rule field k8s_token_env_var names WHICH env var holds the cluster bearer token.
# Example: if rule says k8s_token_env_var=WEISSMAN_K8S_PROD_TOKEN, set:
# WEISSMAN_K8S_PROD_TOKEN=eyJ...
# (fingerprint_engine/src/server_handlers_phase5.inc — std::env::var(rule_env_name)).

# Allow insecure TLS to Kubernetes API (1/true).
WEISSMAN_K8S_INSECURE_TLS=

# -----------------------------------------------------------------------------
# PDF / fonts (fingerprint_engine/src/executive_pdf.rs)
# -----------------------------------------------------------------------------

# Colon-separated (Unix) or semicolon-separated (Windows) font directories for PDF generation.
WEISSMAN_GENPDF_FONT_DIR=

# -----------------------------------------------------------------------------
# Payload signatures & fuzzing (optional)
# -----------------------------------------------------------------------------

# Path to custom payload_signatures.json override.
WEISSMAN_PAYLOAD_SIGNATURES=

# Guided fuzz payload file path (fingerprint_engine/src/fuzzer.rs).
FUZZ_PAYLOADS_FILE=

# Concurrent HTTP feedback fuzz: max in-flight probes (default 100, clamped 8–100).
# WEISSMAN_FUZZ_MAX_IN_FLIGHT=100
# Global requests/sec budget per fuzz run (governor GCRA; default 45 rps, burst ~2×).
# WEISSMAN_FUZZ_GLOBAL_RPS=45
# WEISSMAN_FUZZ_BURST=90
# Random pause between batches (ms); helps evade behavioral WAFs (fingerprint_engine/src/fuzz_http_pool.rs).
# WEISSMAN_FUZZ_BATCH_JITTER_MS_LOW=50
# WEISSMAN_FUZZ_BATCH_JITTER_MS_HIGH=200
# Rotate egress client every N probes when PROXIES_LIST / PROXIES_FILE is set (default 1).
# WEISSMAN_FUZZ_PROXY_ROTATE_EVERY=1

# -----------------------------------------------------------------------------
# Weissman OAST listener (binary: weissman-oast-server, crates/weissman-oast-server)
# -----------------------------------------------------------------------------
# Same DATABASE_URL as the app; requires migration oast_interaction_hits (weissman-db / fingerprint_engine migrations).
# Domain for OAST (Out-of-band Application Security Testing)
WEISSMAN_OAST_DOMAIN=weissmancyber.com
WEISSMAN_OAST_BASE_DOMAIN=weissmancyber.com
# OAST_HTTP_LISTEN=0.0.0.0:9090
# OAST_DNS_LISTEN=0.0.0.0:5353
# OAST_DNS_ENABLE=1
# Optional Bearer for /api/oast/* on the listener.
# WEISSMAN_OAST_API_KEY=
# Fuzzer polls this base URL for correlation (default http://127.0.0.1:9090).
# WEISSMAN_OAST_LISTENER_URL=http://127.0.0.1:9090

# OAST / OOB in payloads (fingerprint_engine/src/fuzz_oob.rs).
# If WEISSMAN_OAST_DOMAIN or WEISSMAN_OAST_BASE_DOMAIN is set, embed defaults to http://{token}.{domain}/i and verify to {WEISSMAN_OAST_LISTENER_URL}/api/oast/status/{token}.
# Override wire templates (must include {token}):
# WEISSMAN_OAST_EMBED_TEMPLATE=https://your-interact-server.example/{token}
# WEISSMAN_OAST_VERIFY_URL=https://your-interact-server.example/verify/{token}
# Plain status response must contain this substring when the token has hits (default oob_hit).
# WEISSMAN_OAST_HIT_SUBSTRING=oob_hit
# Max mutation-derived probes to instrument with OAST per run (default 64).
# WEISSMAN_OAST_MAX_PROBES=64

# Generative vLLM feedback fuzz (fingerprint_engine/src/generative_fuzz_llm.rs, default ON).
# Set to 0/false/off to use legacy static mutations (FUZZ_PAYLOADS_FILE + fuzz_core mutator).
# WEISSMAN_GENERATIVE_FUZZ=1
# Channel buffer + refill threshold, max POST probes per run, LLM HTTP timeout (seconds).
# WEISSMAN_GENERATIVE_FUZZ_CHANNEL_CAP=256
# WEISSMAN_GENERATIVE_FUZZ_LOW_WATER=56
# WEISSMAN_GENERATIVE_FUZZ_MAX_POST_PROBES=640
# WEISSMAN_GENERATIVE_FUZZ_LLM_TIMEOUT_SECS=300
# WEISSMAN_GENERATIVE_FUZZ_TEMPERATURE=0.55
# WEISSMAN_GENERATIVE_FUZZ_MAX_TOKENS=4096
# Comma-separated stack hints injected into LLM prompts (e.g. php,graphql,java).
# WEISSMAN_FUZZ_TECH_STACK=

# Optional egress proxies for fingerprinting and fuzz HTTP pool: comma-separated URLs or one host:port per line in file.
PROXIES_LIST=
PROXIES_FILE=

# Optional region label (read but optional in fingerprint/fuzzer).
WEISSMAN_REGION=

# -----------------------------------------------------------------------------
# Misc server / verification
# -----------------------------------------------------------------------------

# Public base for generated links (defaults http://localhost:8000) (fingerprint_engine/src/server_handlers_rest2.inc).
WEISSMAN_BASE_URL=

# Verification sandbox: require baseline 2xx before success (fingerprint_engine/src/verification_sandbox.rs).
WEISSMAN_VERIFY_REQUIRE_BEFORE_SUCCESS=

# CLI deep scan flag (fingerprint_engine CLI main.rs).
WEISSMAN_DEEP_SCAN=

# -----------------------------------------------------------------------------
# HPC / runtime (Linux)
# -----------------------------------------------------------------------------

# Pin Tokio workers to NUMA nodes when set (fingerprint_engine/src/hpc_runtime.rs).
WEISSMAN_NUMA_PIN=

# -----------------------------------------------------------------------------
# Tests only (do not set in production)
# -----------------------------------------------------------------------------

# TEST_DATABASE_URL=   # crates/weissman-db/tests/rls_cross_tenant.rs
