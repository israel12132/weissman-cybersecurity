# nix-direnv: loads flake devShell (Rust via Fenix, Python 3.12, OpenSSL, PostgreSQL client libs, pkg-config).
# Install: nix profile install nixpkgs#nix-direnv && echo 'eval "$(direnv hook bash)"' >> ~/.bashrc
# Then: direnv allow
use flake

# Local secrets (gitignored). Example:
#   export DATABASE_URL="postgres://weissman_app:...@localhost:5432/weissman"
#   export PADDLE_API_KEY="..."
#   export NVD_API_KEY="..."
source_env_if_exists .envrc.private
