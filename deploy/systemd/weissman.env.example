# Install: sudo install -m 600 -o root -g root weissman.env.example /etc/weissman/weissman.env
# Then: sudo nano /etc/weissman/weissman.env
#
# systemd loads this file; no `export`. No quotes needed unless value has spaces.

# --- Required ---
DATABASE_URL=postgres://weissman_app:CHANGE_ME@127.0.0.1:5432/weissman
WEISSMAN_JWT_SECRET=CHANGE_ME_MIN_32_BYTES_RANDOM_HEX_OR_BASE64

# --- Strongly recommended (production HTTPS) ---
WEISSMAN_COOKIE_SECURE=1
PORT=8080
# WEISSMAN_PUBLIC_BASE_URL=https://command.example.com

# Auth DB (omit to use DATABASE_URL)
# WEISSMAN_AUTH_DATABASE_URL=postgres://weissman_auth:CHANGE_ME@127.0.0.1:5432/weissman

# Migrations on boot (superuser URL — optional if you migrate manually)
# WEISSMAN_MIGRATE_URL=postgres://postgres:CHANGE_ME@127.0.0.1:5432/weissman

# Static UI: default is WorkingDirectory/frontend/dist. Override if needed:
# WEISSMAN_STATIC=/opt/weissman/app/frontend/dist

# Optional env file path for dotenv override chain (loaded by app)
# WEISSMAN_ENV_FILE=/etc/weissman/weissman.env

# Worker concurrency
# WEISSMAN_WORKER_LIGHT_CONCURRENCY=8
# WEISSMAN_WORKER_HEAVY_CONCURRENCY=2

# Tracing
# RUST_LOG=info,weissman_server=info,fingerprint_engine=info

# Intel DB (optional)
# WEISSMAN_INTEL_DATABASE_URL=postgres://...

# First-boot bootstrap (see .env.example in repo)
# WEISSMAN_MASTER_BOOTSTRAP_PASSWORD=...

# --- Pilot / enterprise trial (no Paddle yet) ---
# When unset, billing strict mode defaults ON if PADDLE_API_KEY is set.
# Set to 0 for a free evaluation month: clients + scans work without an active Paddle subscription.
# WEISSMAN_BILLING_STRICT=0
