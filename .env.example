# Copy to .env on the server (e.g. /etc/weissman.env or systemd EnvironmentFile=). chmod 600. Do not commit .env.

# =============================================================================
# PRODUCTION (VPS) — required / strongly recommended
# =============================================================================
# Public URL users type in the browser (no trailing path). Used for OIDC/SAML redirects and correct absolute links.
# WEISSMAN_PUBLIC_BASE_URL=https://weissmancyber.com

# Region identifier (shown in GET /api/config/public; useful for multi-region deployments)
# WEISSMAN_REGION=IL

# Postgres (use host/IP of your DB server, not localhost unless DB is on same VPS)
# DATABASE_URL=postgres://weissman_app:STRONG_PASSWORD@db.internal:5432/weissman
# Optional separate auth DB role:
# WEISSMAN_AUTH_DATABASE_URL=postgres://weissman_auth:STRONG_PASSWORD@db.internal:5432/weissman

# Rust HTTP port (default 8000; matches docker-compose.yml and deploy/nginx-weissman.conf)
# PORT=8000
#
# CEO / God Mode UI calls /api/ceo/telemetry, /api/ceo/jobs/live, /api/ceo/god-mode/snapshot.
# If the browser shows HTTP 404 on those paths, rebuild and restart weissman-server from this repo:
#   cargo build -p weissman-server --release && sudo systemctl restart weissman   # unit name may differ

# Required: HS256 signing key for session JWT. Server refuses to start if unset (no default).
# WEISSMAN_JWT_SECRET=

# HTTPS cookie security: set to 1 in production (HTTPS only). Default is 0 for local dev (http://localhost).
# WEISSMAN_COOKIE_SECURE=1

# If the binary is not started with cwd = repository root, set absolute path to Vite output:
# WEISSMAN_STATIC=/opt/weissman/app/frontend/dist

# First-boot master user (see code for MASTER_BOOTSTRAP_EMAIL); set one of:
# WEISSMAN_MASTER_BOOTSTRAP_PASSWORD=
# WEISSMAN_MASTER_BOOTSTRAP_BCRYPT=

# Superuser URL for sqlx migrations (optional; run once or on deploy)
# WEISSMAN_MIGRATE_URL=postgres://postgres:...@db.internal:5432/weissman

# SAML / OIDC labs: xmlsec path, insecure skip for testing only
# WEISSMAN_XMLSEC1_BINARY=/usr/bin/xmlsec1
# WEISSMAN_SAML_INSECURE_SKIP_VERIFY=0
# WEISSMAN_SAML_SP_ISSUER=

# =============================================================================
# Local / optional
# =============================================================================

# GitHub PAT - for Security Advisories (optional; improves rate limits)
# GITHUB_TOKEN=

# Login seed (development); production uses DB users
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me

# Weissman backend: admin seed for fingerprint_engine (change in production)
# WEISSMAN_ADMIN_EMAIL=admin@example.com
# WEISSMAN_ADMIN_PASSWORD=change-me

# Optional: other intel API keys
# NVD_API_KEY=          # NIST NVD CVE API 2.0 (higher rate limits); PoE exploit synthesis merges keywordSearch results with stack fingerprint
# OTX_API_KEY=
# HIBP_API_KEY=

# Telegram Bot - alerts for high/critical findings and fuzzer reports
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Critical PoE (cURL) alerts — Slack or Discord incoming webhook (also editable in Command Center → Settings & Alerts)
# WEISSMAN_ALERT_WEBHOOK_URL=

# Paddle Billing (B2B SaaS) — sandbox or production API
# PADDLE_ENVIRONMENT=sandbox
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# After checkout, POST /api/billing/sync-paddle (authenticated) refreshes tenant_subscriptions from Paddle API
# Catalog price IDs (pri_...) unless set per-row in billing_plans.paddle_price_id
# WEISSMAN_PADDLE_PRICE_STARTER=
# WEISSMAN_PADDLE_PRICE_PROFESSIONAL=
# WEISSMAN_PADDLE_PRICE_ENTERPRISE=
# Optional override: force strict subscription checks (default: strict when PADDLE_API_KEY is non-empty)
# WEISSMAN_BILLING_STRICT=true

# HPC / large hosts (Linux): NUMA worker pinning (hwloc), HTTP pool tuning — see fingerprint_engine scan_http_client / hpc_runtime
# Pin Tokio workers to explicit CPUs (comma list, ranges allowed). Overrides WEISSMAN_NUMA_PIN when set.
# Example Ryzen split: Rust/Tokio on efficiency block, vLLM on the rest (vLLM is a separate process — use taskset/cgroup on its unit file):
# WEISSMAN_TOKIO_CPU_AFFINITY=0-7
# ExecStart=/usr/bin/taskset -c 8-31 /path/to/python -m vllm.entrypoints.openai.api_server ...
# WEISSMAN_NUMA_PIN=1
# WEISSMAN_HTTP_POOL_MAX_IDLE=256
# WEISSMAN_HTTP_POOL_IDLE_SECS=600
# WEISSMAN_HTTP_TCP_KEEPALIVE_SECS=60

# General (vLLM strategic brain): POST /api/general/mission enqueues ASM → LLM path refine → semantic fuzz; POST /api/general/self-audit
# Optional periodic self-audit (tenant id required; min interval 600s enforced)
# WEISSMAN_GENERAL_SELF_AUDIT_INTERVAL_SECS=0
# WEISSMAN_GENERAL_SELF_AUDIT_TENANT_ID=1

# Council (MoA adversarial debate): POST /api/council/debate → job `council_debate`. Per-tenant `llm_base_url` / `llm_model` from DB; override model slots:
# WEISSMAN_COUNCIL_MODEL_CODER=          # Alpha (+ parallel paths); defaults to tenant llm_model
# WEISSMAN_COUNCIL_MODEL_GENERALIST=   # Beta defender; alias WEISSMAN_COUNCIL_MODEL_DEFENDER
# WEISSMAN_COUNCIL_MODEL_SYNTHESIZER=  # Gamma; defaults to coder model
# WEISSMAN_COUNCIL_TIMEOUT_SECS=120
# WEISSMAN_COUNCIL_PARALLEL_ALPHA=0    # 1/true: three concurrent Alpha calls (Ryzen / vLLM throughput)
# WEISSMAN_COUNCIL_TEMP_ALPHA=0.35
# WEISSMAN_COUNCIL_TEMP_BETA=0.2
# WEISSMAN_COUNCIL_TEMP_GAMMA=0.25
# WEISSMAN_COUNCIL_MAX_TOKENS_ALPHA=2048
# WEISSMAN_COUNCIL_MAX_TOKENS_BETA=2048
# WEISSMAN_COUNCIL_MAX_TOKENS_GAMMA=4096
# WEISSMAN_COUNCIL_EMBEDDING_MODEL=text-embedding-3-small   # /v1/embeddings for supreme_council_memory (OpenAI-compatible)
# WEISSMAN_LLM_DISABLE_JSON_RESPONSE_FORMAT=0   # set 1 if vLLM rejects response_format json_object (Supreme Command / council JSON mode)
# WEISSMAN_COUNCIL_DEBATE_SIGNING_SECRET=       # HMAC-SHA256 for COUNCIL_DEBATE audit signatures; falls back to WEISSMAN_JWT_SECRET, else SHA256-only digest

# Supreme Council (POST /api/council/debate JSON `"supreme": true`): DeepSeek-Coder-V3 ∥ Mistral-Large-3 → Llama-4 Sovereign General; OAST success → Postgres semantic memory
# WEISSMAN_SUPREME_COUNCIL=1              # default model IDs: DeepSeek-Coder-V3, Mistral-Large-3, Llama-4-70B-Q4_K_M when per-slot env above unset
# WEISSMAN_SUPREME_COUNCIL_AFFINITY=1      # Linux: bind phased LLM worker threads (Ryzen 9 5950X-style CCX batching)
# WEISSMAN_SUPREME_PHASE1_CPUS=8-23        # Proposer + Critic parallel (logical CPUs)
# WEISSMAN_SUPREME_PHASE2_CPUS=24-31       # Sovereign General alone
# WEISSMAN_SUPREME_MEMORY_TOP_K=5          # prior wins injected into Proposer context (cosine on stored embeddings)

# Sovereign Evolution (learning buffer, shadow pre-flight, autonomous pivot): master switch + Tokio parallel LLM sims (default 32)
# WEISSMAN_SOVEREIGN_EVOLUTION=1
# WEISSMAN_STRATEGIC_THINKING_CONCURRENCY=32
# Async job `sovereign_learning_feedback`: payload { "target_seed": "...", "failure_context": { ... } } → Postgres `sovereign_learning_buffer` + Critic→Hacker JSON
# `feedback_fuzz` / generative path: optional `cognitive_dictionary` string array (OSINT terms) biases LLM mutation prompts
# `deep_fuzz`: optional `cognitive_dictionary` (merged ahead of `discovered_paths`); `shadow_preflight` true runs vLLM risk sim when evolution enabled; `autonomous_credential_pivot` true may enqueue `leak_hunter` on low-priv secret signals

# Genesis Protocol (preemptive research + vaccine vault + onboarding match). Rust worker jobs: `genesis_eternal_fuzz`, `genesis_knowledge_match`
# WEISSMAN_GENESIS_PROTOCOL=1
# WEISSMAN_GENESIS_SEED_REPOS=owner/repo,https://github.com/org/other   # comma-separated; also WEISSMAN_GENESIS_SEED_NPM / _CRATES / _PYPI / _IMAGES
# WEISSMAN_GENESIS_DFS_MAX_DEPTH=8
# WEISSMAN_GENESIS_DFS_MAX_STEPS=   # optional fuse; omit for usize::MAX (RAM hibernation is primary)
# WEISSMAN_GENESIS_RAM_BUDGET_MB=4096   # soft offload at 85% of this budget (RSS via /proc/self/status VmRSS)
# WEISSMAN_GENESIS_RESEARCH_CPU_AFFINITY=0-15
# WEISSMAN_GENESIS_CLIENT_SCAN_CPU_AFFINITY=16-31   # use on second worker + WEISSMAN_TOKIO_CPU_AFFINITY for scan isolation
# WEISSMAN_GENESIS_AUTO_POE=1                       # enqueue `poe_synthesis_run` after validated vault row when component ref resolves to a URL
# Job `genesis_eternal_fuzz` JSON: `"resume_suspended_id": 123` to continue from `genesis_suspended_graphs`; optional `"enqueue_supply_chain_seeds": true`, `"run_council_war_room": false`
# In-process DashMap mirrors `genesis_vaccine_vault` for fast match (Postgres remains source of truth; not cross-process shared memory)

# Ghost Swarm client fingerprint rings on fuzz HTTP probes (User-Agent / Accept-Language / Sec-CH-UA-Platform). IP rotation = PROXIES_LIST.
# WEISSMAN_GHOST_SWARM_FINGERPRINT=0

# OAST (out-of-band interaction tracking): fuzz/embed uses http://{token}.{domain}/i; verify polls WEISSMAN_OAST_LISTENER_URL
# WEISSMAN_OAST_DOMAIN=weissmancyber.com
# WEISSMAN_OAST_BASE_DOMAIN=weissmancyber.com   # legacy alias; same value as WEISSMAN_OAST_DOMAIN if both set
# WEISSMAN_OAST_LISTENER_URL=https://your-oast-origin.example.com:9090
# WEISSMAN_OAST_API_KEY=   # optional Bearer for /api/oast/*

# Optional SMTP when WEISSMAN_SMTP_ENABLED=true (same alert path as webhook)
# WEISSMAN_SMTP_ENABLED=false
# WEISSMAN_SMTP_HOST=
# WEISSMAN_SMTP_PORT=587
# WEISSMAN_SMTP_USER=
# WEISSMAN_SMTP_PASSWORD=
# WEISSMAN_SMTP_FROM=
# WEISSMAN_SMTP_TO=

# Sovereign C2 (optional): bounded mpsc fan-out to swarm tasks; signed API port hints; honeytoken rotation telemetry; Cloudflare full-cloak from security_events
# WEISSMAN_SOVEREIGN_MPSC_CAPACITY=256
# WEISSMAN_SOVEREIGN_SWARM_HMAC_SECRET=   # port-hint MAC; falls back to WEISSMAN_JWT_SECRET if unset
# WEISSMAN_SOVEREIGN_PORT_HOP_INTERVAL_SECS=0   # >0 writes signed JSON to path below (operators must bind listener)
# WEISSMAN_SOVEREIGN_PORT_HINT_PATH=/run/weissman/command_api_port.json
# WEISSMAN_SOVEREIGN_PORT_MIN=40000
# WEISSMAN_SOVEREIGN_PORT_MAX=41000
# WEISSMAN_SOVEREIGN_HONEYTOKEN_INTERVAL_SECS=0   # requires mpsc capacity; HS256 + Ed25519-shaped material

# Cloudflare zone under_attack when many distinct IPs hit security_events (requires CF token + zone + explicit ack)
# WEISSMAN_FULL_CLOAK_ENABLE=0
# WEISSMAN_FULL_CLOAK_I_ACKNOWLEDGE_BROAD_IMPACT=0
# WEISSMAN_CF_API_TOKEN=
# WEISSMAN_CF_ZONE_ID=
# WEISSMAN_FULL_CLOAK_WINDOW_SECS=300
# WEISSMAN_FULL_CLOAK_MIN_DISTINCT_IPS=8
# WEISSMAN_FULL_CLOAK_POLL_SECS=60
# WEISSMAN_FULL_CLOAK_COOLDOWN_SECS=600

# Process panic: exit non-zero for systemd/docker restart (clean state) — only with explicit ack
# WEISSMAN_PANIC_EXIT_ON_FATAL=0
# WEISSMAN_PANIC_EXIT_I_ACKNOWLEDGE_RESTART=0

# Generative fuzz: pivot LLM bypass prompts when successive WAF-block excerpts show dropping Shannon entropy (tunable threshold)
# WEISSMAN_FUZZ_ENTROPY_DROP_EPS=0.04

# Deception canary → Cloudflare IPv4 /24 block (broad; explicit ack). Skips RFC1918 unless allow-private is set.
# WEISSMAN_DECEPTION_CF_BLACKHOLE_ENABLE=0
# WEISSMAN_DECEPTION_CF_BLACKHOLE_I_ACKNOWLEDGE_ISP_IMPACT=0
# WEISSMAN_DECEPTION_CF_BLACKHOLE_ALLOW_PRIVATE=0
# Canary payloads may include ASN — Cloudflare access rule targets ASN first, then falls back to /24.

# General / Ascension: mission map from clients + asm_graph_nodes → risk-ranked job enqueue (explicit ack)
# WEISSMAN_ASCENSION_AUTONOMOUS_ENQUEUE=0
# WEISSMAN_ASCENSION_AUTONOMOUS_I_ACKNOWLEDGE=0
# WEISSMAN_ASCENSION_MAX_JOBS=6
# WEISSMAN_ASCENSION_LLM_RANK=0   # vLLM re-orders client priority from mission map
# POST /api/general/ascension enqueues job kind ascension_wave

# After feedback_fuzz persists ≥1 finding, enqueue extra poe_synthesis_run (optional; can duplicate orchestrator PoE)
# WEISSMAN_ASCENSION_AUTO_POE_SYNTHESIS=0
# WEISSMAN_ASCENSION_AUTO_POE_I_ACKNOWLEDGE=0
