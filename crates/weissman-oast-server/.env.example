# Copy to .env for local runs. Do not commit .env with secrets.
DATABASE_URL=postgres://weissman_app:password@127.0.0.1:5432/weissman

# Wildcard DNS must resolve *.{domain} to this service (e.g. Cloudflare → origin).
WEISSMAN_OAST_DOMAIN=weissmancyber.com
# WEISSMAN_OAST_BASE_DOMAIN=weissmancyber.com

OAST_HTTP_LISTEN=0.0.0.0:9090
# OAST_DNS_LISTEN=0.0.0.0:5353
# OAST_DNS_ENABLE=1
# WEISSMAN_OAST_API_KEY=
